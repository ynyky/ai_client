SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PARENT_DIR="$(dirname "$SCRIPT_DIR")"

docker run \
  -e ANTHROPIC_API_KEY \
  --env-file .ai_env \
  -v "$PARENT_DIR/workspace:/home/claude/workspace" \
  -v "$PARENT_DIR/claude_config/.claude:/home/claude/.claude" \
  -v "$PARENT_DIR/claude_config/.claude.json:/home/claude/.claude.json" \
  -it ai-client:latest